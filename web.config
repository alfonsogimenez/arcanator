<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.config for Arcanator on IIS with ARR (Application Request Routing)
  ========================================================================
  Requirements:
    - IIS ARR module installed  → https://www.iis.net/downloads/microsoft/application-request-routing
    - IIS URL Rewrite module    → https://www.iis.net/downloads/microsoft/url-rewrite
    - uvicorn running on        → http://127.0.0.1:8000  (see start.bat)

  This config proxies ALL traffic to uvicorn so FastAPI serves both the
  frontend static files and the API. IIS acts purely as a reverse proxy.

  SSE note: ARR buffers responses by default, which breaks Server-Sent Events.
  The responseBufferLimit="0" below disables buffering for this site.
-->
<configuration>
  <system.webServer>

    <!-- Disable response buffering so SSE events are flushed immediately -->
    <asp enableChunkedEncoding="true" />

    <rewrite>
      <rules>
        <rule name="Arcanator Reverse Proxy" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <!-- Avoid proxy loop -->
            <add input="{HTTP_HOST}" pattern="^127\.0\.0\.1(:\d+)?$" negate="true" />
          </conditions>
          <action type="Rewrite" url="http://127.0.0.1:8000/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- Disable IIS compression on SSE/stream endpoints to prevent buffering -->
    <urlCompression doStaticCompression="false" doDynamicCompression="false" />

    <!-- Increase request body size limit for large audio uploads (500 MB) -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="524288000" />
      </requestFiltering>
    </security>

    <!-- Pass through WebSocket upgrades if needed -->
    <webSocket enabled="false" />

  </system.webServer>

  <system.web>
    <!-- Increase HTTP runtime limits -->
    <httpRuntime maxRequestLength="512000" executionTimeout="3600" />
  </system.web>
</configuration>
